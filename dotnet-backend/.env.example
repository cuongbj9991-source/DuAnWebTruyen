# .NET ASP.NET Core User Service Configuration

# Database Connection
ConnectionString=Host=localhost;Port=5432;Database=doctruyen;Username=postgres;Password=postgres;

# JWT Settings
JWT_SECRET=your-secret-key-change-in-production-very-long-string-for-256-bits-minimum
JWT_ISSUER=doctruyen-api
JWT_AUDIENCE=doctruyen-client
JWT_DURATION_MINUTES=1440

# Email Settings (Optional - for OTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_PASSWORD=your-app-password

# Server
SERVER_PORT=5001

# CORS
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=Information
